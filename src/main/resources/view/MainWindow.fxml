<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane fx:controller="MainWindow" prefHeight="600.0" prefWidth="420.0"
            stylesheets="@/css/app.css,@/css/main.css" xmlns:fx="http://javafx.com/fxml">
    <Button onAction="#handleBack" text="Back" styleClass="ghost compact" AnchorPane.topAnchor="12.0" AnchorPane.leftAnchor="16.0" />
    <ScrollPane fx:id="scrollPane" fitToWidth="true" AnchorPane.topAnchor="52.0" AnchorPane.leftAnchor="12.0"
                AnchorPane.rightAnchor="12.0" AnchorPane.bottomAnchor="76.0">
        <VBox fx:id="dialogContainer" prefHeight="-Infinity" spacing="10.0" />
    </ScrollPane>
    <TextField fx:id="userInput" onAction="#handleUserInput" promptText="Type a command…"
               AnchorPane.bottomAnchor="16.0" AnchorPane.leftAnchor="16.0" AnchorPane.rightAnchor="88.0" />
    <Button fx:id="sendButton" onAction="#handleUserInput" prefWidth="64.0" text="Send" styleClass="compact"
            AnchorPane.bottomAnchor="16.0" AnchorPane.rightAnchor="16.0" />
</AnchorPane>
