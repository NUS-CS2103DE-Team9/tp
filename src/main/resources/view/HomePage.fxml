<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane fx:controller="HomePageController" prefHeight="240.0" prefWidth="400.0"
            stylesheets="@/css/app.css,@/css/home.css" xmlns:fx="http://javafx.com/fxml">
    <VBox alignment="CENTER" spacing="16.0" styleClass="home-panel"
          AnchorPane.bottomAnchor="40.0" AnchorPane.leftAnchor="40.0" AnchorPane.rightAnchor="40.0" AnchorPane.topAnchor="40.0">
        <Label text="Select user" styleClass="dialog-title" />
        <Label text="Choose a senior profile to open the assistant" styleClass="caption" wrapText="true" />
        <ComboBox fx:id="userCombo" prefWidth="260.0" />
        <Button onAction="#handleEnter" text="Continue" prefWidth="260.0" />
    </VBox>
</AnchorPane>
